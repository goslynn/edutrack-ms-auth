meta {
  name: Revoke user sessions
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/users/{{userId}}/sessions
  body: none
  auth: inherit
}

headers {
  X-User-Roles: {{userRoles}}
}

docs {
  Revoca todos los refresh tokens activos del usuario. Útil para forzar el
  cierre de sesión remoto desde un panel de administración.
}
