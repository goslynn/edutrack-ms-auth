meta {
  name: Upsert permission
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/roles/{{roleId}}/permissions/:resourceUuid
  body: json
  auth: inherit
}

params:path {
  resourceUuid: {{resourceUuid}}
}

headers {
  Content-Type: application/json
  X-User-Roles: {{userRoles}}
}

body:json {
  {
    "flags": 7
  }
}

docs {
  Crea o actualiza el permiso (roleId, resourceUuid).
  flags: r=4, w=2, x=1. Por ejemplo:
    - 4 → r--
    - 6 → rw-
    - 7 → rwx
}
