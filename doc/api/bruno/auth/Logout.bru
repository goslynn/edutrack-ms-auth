meta {
  name: Logout
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/logout
  body: none
  auth: none
}

headers {
  X-User-Id: {{userId}}
}

docs {
  Revoca todos los refresh tokens del usuario indicado en `X-User-Id`.
  Tras esto, ningún refresh token activo del usuario podrá renovarse.
}
