meta {
  name: Create role
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/roles
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  X-User-Roles: {{userRoles}}
}

body:json {
  {
    "name": "COORDINADOR",
    "description": "Coordinador académico"
  }
}

script:post-response {
  if (res.status === 201 && res.body && res.body.id) {
    bru.setVar("roleId", res.body.id);
  }
}

docs {
  Crea un rol nuevo. El nombre debe ser único.
}
